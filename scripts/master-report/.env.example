# Master Report Generator — environment template
# ==================================================
# 1. Copy this file to .env (which is gitignored)
# 2. Fill in the real values
# 3. Run: python3 generate_report.py
#
# generate_report.py reads ONLY these four variables (via get_config at
# generate_report.py:51-66). Anything with a VITE_* prefix is ignored.

# Supabase project URL. MUST be the active project: ksbblqnwcmfylpxygyrj.
# NEVER point this at the old inactive project agmcauhjhfwksrjllxar.
SUPABASE_URL=https://ksbblqnwcmfylpxygyrj.supabase.co

# Supabase API key. MUST be the service_role key (not anon), because the
# generator needs to bypass RLS to read every user's answer_history and
# spaced_repetition rows. The anon key is limited by RLS and causes
# fetch_data to return empty collections — the fail-fast sentinel will abort.
# Rotate this key after any session it appears in plaintext.
SUPABASE_KEY=

# The auth.users UUID of the user whose progress you want to report on.
# Fetch via Supabase SQL editor:
#     SELECT id FROM auth.users WHERE email = 'idankatz64@gmail.com';
USER_ID=

# Optional — defaults to 2026-06-16 inside get_config if omitted.
# Format: YYYY-MM-DD
EXAM_DATE=2026-06-16
